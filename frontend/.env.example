# ── Frontend environment variables ───────────────────────────────────────────
# All VITE_ prefixed vars are bundled into the browser JS — NEVER put secrets here.

# Backend API URL
# In development: leave empty (Vite proxy handles /api, /auth, etc.)
# In production: set to your deployed backend URL
VITE_API_URL=

# App name (optional — shown in browser tab)
VITE_APP_NAME=BrandForge Studio
