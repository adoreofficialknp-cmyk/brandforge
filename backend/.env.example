# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/brandforge

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-in-production

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@brandforge.com
ADMIN_PASSWORD=Admin@BrandForge2025
ADMIN_NAME=BrandForge Admin

# ── Anthropic AI (server-side only — never expose to frontend) ────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Unsplash (stock photos) ───────────────────────────────────────────────────
# Get free key at https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your-unsplash-access-key-here

# ── Razorpay ──────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ── Email (for password reset) ────────────────────────────────────────────────
# Use Gmail App Password, Resend, or any SMTP provider
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=BrandForge <noreply@brandforge.com>
APP_URL=https://your-app.onrender.com
